LITELLM_MASTER_KEY=sk-local-dev-master-key
LITELLM_SALT_KEY=sk-local-dev-salt-key-32-chars-minimum

STORE_MODEL_IN_DB=True

# Used by backend and worker for GitHub bundle import/sync/push.
# The web UI never collects this token.
GITHUB_PAT=replace-me

# Used for git commits created by optimization writeback.
GIT_COMMIT_NAME=DSPy Trainer
GIT_COMMIT_EMAIL=dspy-trainer@local

# Required to encrypt/decrypt module environment entries stored in Postgres.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DSPY_TRAINER_MODULE_ENV_ENCRYPTION_KEY=replace-with-generated-fernet-key

# Optional: number of MLflow web workers to run in docker-compose.
# Increase if trace and run UI/API requests time out under load.
MLFLOW_WEB_WORKERS=4

# Optional: number of dedicated endpoint worker containers to run in docker-compose.
# These workers are assigned to managed bundle endpoints based on each endpoint's pinned worker count.
DSPY_TRAINER_TOTAL_ENDPOINT_WORKERS=2

# Public URLs baked into the web build. The backend also derives allowed CORS origins from these URLs.
VITE_API_BASE_URL=http://localhost:8000
VITE_MLFLOW_BASE_URL=http://localhost:5001
VITE_LITELLM_BASE_URL=http://localhost:4000

# Optional explicit CORS origins to allow in addition to the public URLs above.
DSPY_TRAINER_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
