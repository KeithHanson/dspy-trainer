LITELLM_MASTER_KEY=sk-local-dev-master-key
LITELLM_SALT_KEY=sk-local-dev-salt-key-32-chars-minimum

STORE_MODEL_IN_DB=True

# Used by backend and worker for GitHub bundle import/sync/push.
# The web UI never collects this token.
GITHUB_PAT=replace-me

# Used for git commits created by optimization writeback.
GIT_COMMIT_NAME=DSPy Trainer
GIT_COMMIT_EMAIL=dspy-trainer@local
