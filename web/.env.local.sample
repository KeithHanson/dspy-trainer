VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_AUDIENCE=

# IMPORTANT: point this at the backend API, not the web dev server
VITE_API_BASE_URL=http://localhost:8000

# Optional Auth0 connection names for explicit provider buttons
VITE_AUTH0_CONNECTION_GITHUB=
VITE_AUTH0_CONNECTION_GOOGLE=
VITE_AUTH0_CONNECTION_MICROSOFT=
VITE_AUTH0_CONNECTION_SSO=

# Optional Auth0 SPA behavior
VITE_AUTH0_CACHE_LOCATION=localstorage
VITE_AUTH0_USE_REFRESH_TOKENS=false
